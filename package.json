    "@types/express": "^5.0.6",
    "@types/mermaid": "^9.1.0",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
